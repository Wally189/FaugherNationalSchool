---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import QuickLinks from "../components/QuickLinks.astro";
import AlertBanner from "../components/AlertBanner.astro";
import "../styles/global.css";
import { getEntry } from "astro:content";
import { siteConfig } from "../site.config";
import { withBase } from "../utils/links";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const metaDescription = description ?? siteConfig.description;
const canonical = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const alertEntry = await getEntry("settings", "alert");
const rawOgImage = ogImage ?? siteConfig.socialImage;
const resolvedOgImage = /^https?:\/\//.test(rawOgImage)
  ? rawOgImage
  : new URL(withBase(rawOgImage), siteConfig.siteUrl).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {siteConfig.schoolName}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.schoolName} />
    <meta property="og:title" content={`${title} | ${siteConfig.schoolName}`} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${siteConfig.schoolName}`} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <AlertBanner alert={alertEntry?.data} />
    <Header />
    <QuickLinks />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
