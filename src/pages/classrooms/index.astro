---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Classrooms" description="Junior Room, Senior Room, and school achievements.">
  <section class="section">
    <div class="container page-intro">
      <h1>Classrooms</h1>
      <p>This section shares updates from class life and celebrates pupil achievements.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid-two">
      <article class="panel prose">
        <h2>Junior Room</h2>
        <p>Add class updates, learning themes, and age-appropriate highlights here.</p>
      </article>

      <article class="panel prose">
        <h2>Senior Room</h2>
        <p>Add project work, leadership activities, and senior class highlights here.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container panel prose">
      <h2>Achievements</h2>
      <p>Share awards, sporting milestones, creative projects, and community achievements.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Photo Gallery Placeholders</h2>
      <div class="gallery-placeholders">
        <img src="/images/gallery-placeholder.svg" alt="Gallery placeholder for classroom photos" loading="lazy" />
        <img src="/images/gallery-placeholder.svg" alt="Gallery placeholder for school event photos" loading="lazy" />
        <img src="/images/gallery-placeholder.svg" alt="Gallery placeholder for achievement photos" loading="lazy" />
      </div>
    </div>
  </section>
</BaseLayout>
