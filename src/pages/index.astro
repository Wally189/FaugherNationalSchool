---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/NewsCard.astro";
import EventCard from "../components/EventCard.astro";
import principalPhoto from "../assets/images/principal-dolores.jpg";
import { getUpcomingEvents } from "../utils/events";

const news = (await getCollection("news", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latestNews = news.slice(0, 3);

const events = await getCollection("events", ({ data }) => !data.draft);
const upcomingEvents = getUpcomingEvents(events).slice(0, 3);
---
<BaseLayout title="Home" description="Welcome to Faugher National School.">
  <section class="section">
    <div class="container hero">
      <div class="hero-text">
        <h1>Welcome to Faugher National School</h1>
        <p>
          Faugher National School is a welcoming, fun, and happy learning environment where every child is encouraged
          to reach their fullest potential.
        </p>
        <div class="hero-actions">
          <a class="button" href="/contact-us">Contact Us</a>
          <a class="button secondary" href="/parents-information">Parents Information</a>
          <a class="button secondary" href="/school-news">Latest News</a>
        </div>
      </div>

      <aside class="panel">
        <Image
          src={principalPhoto}
          alt="Principal portrait"
          width={640}
          height={360}
          loading="lazy"
          decoding="async"
        />
        <h2>Principal Welcome</h2>
        <p>
          It is a pleasure to welcome you to our school website. It offers a glimpse into the caring and positive school
          life for which Faugher National School is known.
        </p>
        <p><a href="/our-school">Read the full welcome and learn more about our ethos.</a></p>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Explore</h2>
      <div class="cards">
        <a class="card-link" href="/parents-information">
          <article class="panel">
            <h3>Parents Information</h3>
            <p>Daily routines, healthy lunches, uniforms, homework, and key policies.</p>
          </article>
        </a>
        <a class="card-link" href="/school-news">
          <article class="panel">
            <h3>School News</h3>
            <p>Recent updates from school life, Gaeilge, sports, and achievements.</p>
          </article>
        </a>
        <a class="card-link" href="/school-events">
          <article class="panel">
            <h3>School Events</h3>
            <p>Upcoming activities, parent meetings, celebrations, and school calendar entries.</p>
          </article>
        </a>
        <a class="card-link" href="/our-school">
          <article class="panel">
            <h3>Our School</h3>
            <p>Our ethos, principal welcome, and an overview of our staff and school community.</p>
          </article>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Latest News</h2>
      <div class="grid-two">
        {latestNews.map((post) => (
          <NewsCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Upcoming Events</h2>
      {upcomingEvents.length > 0 ? (
        <div class="grid-two">
          {upcomingEvents.map((event) => (
            <EventCard event={event} />
          ))}
        </div>
      ) : (
        <p class="notice">There are no upcoming events right now. Please check back soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
