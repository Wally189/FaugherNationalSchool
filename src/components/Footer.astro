---
import { siteConfig } from "../site.config";
import { withBase } from "../utils/links";

const year = new Date().getFullYear();
const dateTime = new Date().toLocaleString("en-GB", { dateStyle: "medium", timeStyle: "short" });
---
<footer class="site-footer">
  <div class="container footer-grid">
    <section>
      <h2>{siteConfig.schoolName}</h2>
      <p>{siteConfig.contact.address}</p>
    </section>

    <section>
      <h2>Contact</h2>
      <p><a href={`tel:${siteConfig.contact.phoneHref}`}>{siteConfig.contact.phone}</a></p>
      <p><a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></p>
    </section>

    <section>
      <h2>Useful</h2>
      <p><a href={withBase("/parents-information#opening-times")}>Opening Times</a></p>
      <p><a href={withBase("/parents-information#downloads")}>Downloads</a></p>
    </section>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {year} {siteConfig.schoolName}</p>
    <p class="footer-meta" style="text-align: right;"><span data-datetime>{dateTime}</span></p>
    <div class="waylight-legal-block" data-waylight-legal style="text-align: right;">
      <p class="waylight-legal-links">
        <a href={withBase("/gdpr")}>GDPR</a> | <a href={withBase("/privacy")}>Privacy</a> |
        <a href={withBase("/terms")}>Terms</a>
      </p>
      <p class="waylight-legal-location">Bristol, United Kingdom</p>
      <p class="waylight-legal-copyright">
        &copy; 2026 <a href="https://www.waylight-atlantic.co.uk/" rel="noreferrer">Waylight Atlantic</a>
      </p>
    </div>
  </div>
</footer>
