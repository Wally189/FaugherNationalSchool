---
import type { CollectionEntry } from "astro:content";
import { formatDateTime } from "../utils/date";
import { withBase } from "../utils/links";

interface Props {
  event: CollectionEntry<"events">;
}

const { event } = Astro.props;
---
<article class="event-card" id={`event-${event.id}`}>
  <div class="card-content">
    <p class="eyebrow">Event</p>
    <h3>{event.data.title}</h3>
    <p class="meta">{formatDateTime(event.data.start)}</p>
    <p><strong>Location:</strong> {event.data.location}</p>
    <p>{event.data.description}</p>
    {event.data.attachment ? (
      <p><a href={withBase(event.data.attachment)}>{event.data.attachmentLabel ?? "Download attachment (PDF)"}</a></p>
    ) : null}
  </div>
</article>
